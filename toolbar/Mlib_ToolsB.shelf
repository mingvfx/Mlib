  <tool name="mlibcreategeo" label="Mlib CreateGeo" icon="BUTTONS_jump">
    <script scriptType="python"><![CDATA[import importlib
import mlib_script

importlib.reload(mlib_script)

mlib_script.create_geo()
]]></script>
  </tool>

