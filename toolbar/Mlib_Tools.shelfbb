opparm $_obj_boxes_color1  ramp ( 2 )
opparm $_obj_boxes_color1 group ( 1 ) class ( 1 ) color ( 0.57999999999999996 0.02 0.02 ) ramp2pos ( 1 ) ramp2c ( 1 1 1 )
opcolor -c 0.80000001192092896 0.80000001192092896 0.80000001192092896 $_obj_boxes_color1
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F off -c off -e on -b off $_obj_boxes_color1
