opparm -V 2 $_obj_boxes_assemble connect ( off ) pack_geo ( on ) createpath ( on ) path ( 'op:`opfullpath(\'.\')/pack' )
opcolor -c 0.80000001192092896 0.80000001192092896 0.80000001192092896 $_obj_boxes_assemble
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F off -c on -e on -b off $_obj_boxes_assemble
opexprlanguage -s hscript $_obj_boxes_assemble
opuserdata -n '___Version___' -v '2' $_obj_boxes_assemble
opuserdata -n '___toolcount___' -v '5' $_obj_boxes_assemble
