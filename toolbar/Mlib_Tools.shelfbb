opcf $arg1

# Node $_obj_boxes_pointwrangle (Sop/attribwrangle)
set _obj_boxes_pointwrangle = `run("opadd -e -n -v attribwrangle pointwrangle")`
oplocate -x `$arg2 + 0` -y `$arg3 + -6.7770000000000001` $_obj_boxes_pointwrangle
opparm $_obj_boxes_pointwrangle  bindings ( 0 ) groupbindings ( 0 )
opparm $_obj_boxes_pointwrangle snippet ( 'if (@ptnum == 0)\n{\n    v@v = set(-55, 0, 0);\n    v@w = set(0, 0, 6);\n}\nelse\n{\n    v@v = set(4, 0, 0);\n    v@w = set(0, 0, 0);\n}\n' )
opcolor -c 0.80000001192092896 0.80000001192092896 0.80000001192092896 $_obj_boxes_pointwrangle
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F off -c off -e on -b off $_obj_boxes_pointwrangle
