opparm $_obj_boxes_color3  ramp ( 2 )
opparm $_obj_boxes_color3 group ( 5 ) class ( 1 ) color ( 0.002 0.53000000000000003 0.002 ) ramp2pos ( 1 ) ramp2c ( 1 1 1 )
opcolor -c 0.80000001192092896 0.80000001192092896 0.80000001192092896 $_obj_boxes_color3
opset -d off -r off -h off -f off -y off -t off -l off -s off -u off -F off -c off -e on -b off $_obj_boxes_color3
